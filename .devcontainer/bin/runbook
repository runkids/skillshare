#!/usr/bin/env bash
set -euo pipefail

WORKSPACE_ROOT="${SKILLSHARE_DEV_WORKSPACE_ROOT:-/workspace}"
TMP_BIN="/tmp/runbook-dev"

if [ ! -d "$WORKSPACE_ROOT" ] || [ ! -f "$WORKSPACE_ROOT/go.mod" ]; then
  echo "devcontainer workspace not found: $WORKSPACE_ROOT" >&2
  exit 1
fi

GO_BIN="${SKILLSHARE_DEV_GO_BIN:-/usr/local/go/bin/go}"
if [ ! -x "$GO_BIN" ]; then
  GO_BIN="$(command -v go || true)"
fi

if [ -z "$GO_BIN" ]; then
  echo "go toolchain not found in devcontainer" >&2
  exit 1
fi

if ! (cd "$WORKSPACE_ROOT" && "$GO_BIN" build -o "$TMP_BIN" ./tools/runbook); then
  echo "failed to build runbook binary" >&2
  exit 1
fi

# Resolve relative runbook paths against workspace root.
# ssenv changes HOME, so relative paths like "ai_docs/tests/..." won't
# resolve from the isolated HOME. Rewrite them to absolute workspace paths.
args=()
for arg in "$@"; do
  if [[ "$arg" != -* ]] && [[ "$arg" != /* ]]; then
    candidate="$WORKSPACE_ROOT/$arg"
    if [ -e "$candidate" ]; then
      arg="$candidate"
    fi
  fi
  args+=("$arg")
done

exec "$TMP_BIN" "${args[@]}"
